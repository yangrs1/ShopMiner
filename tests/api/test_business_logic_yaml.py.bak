@allure.feature("дёҡеҠЎйҖ»иҫ‘йӘҢиҜҒ")
class TestProductStockValidation:

    @allure.story("еә“еӯҳж ЎйӘҢ")
    @allure.severity(allure.severity_level.NORMAL)
    @allure.title("BIZ-011 и¶…еә“еӯҳж•°йҮҸеҠ иҙӯвҶ’иҝ”еӣһ400")
    def test_add_to_cart_exceeds_stock(self, client, auth_headers, app):
        with allure.step("1. жҹҘзңӢе•Ҷе“Ғеә“еӯҳ"):
            with app.app_context():
                from app.models.product import Product
                product = db.session.get(Product, 1)
                stock = product.stock

        with allure.step(f"2. е°қиҜ•еҠ иҙӯи¶…иҝҮеә“еӯҳзҡ„ж•°йҮ?{stock + 100})"):
            resp = client.post("/api/v1/cart", headers=auth_headers, json={
                "product_id": 1,
                "quantity": stock + 100,
            })
            assert resp.status_code == 400
            assert "stock" in resp.get_json()["message"].lower()


@allure.feature("дёҡеҠЎйҖ»иҫ‘йӘҢиҜҒ")
class TestOrderStockDeduction:

