# Flask 应用密钥（必填，生产环境请设置为随机字符串）
APP_SECRET_KEY=
# JWT 签名密钥（必填，生产环境请设置为随机字符串）
JWT_SECRET_KEY=
# 数据库连接 URI（默认 PostgreSQL，开发可改为 sqlite:///shopminer.db）
DB_URI=postgresql://shopminer:shopminer@localhost:5432/shopminer
# 应用基础 URL
BASE_URL=http://127.0.0.1:5000
# Flask 运行环境 (development/production/testing)
FLASK_ENV=development
# CORS 允许的域名来源，逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5000
# JWT Access Token 过期时间（秒）
JWT_ACCESS_TOKEN_EXPIRES=3600
# 文件上传目录
UPLOAD_FOLDER=static/uploads
# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
